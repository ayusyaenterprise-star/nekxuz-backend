rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read/write for orders (in production, restrict this)
    match /orders/{orderId} {
      allow read: if request.auth != null || request.query.email == resource.data.buyerEmail;
      allow create: if request.resource.data.buyerEmail != null;
      allow update, delete: if request.auth != null;
    }

    // Allow authenticated users to read/write payments
    match /payments/{paymentId} {
      allow read, write: if request.auth != null;
    }

    // Allow authenticated users to read/write shipments
    match /shipments/{shipmentId} {
      allow read, write: if request.auth != null;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
