# 🌐 Nekxuz B2B Platform - Environment Configuration
# Copy this file to .env.production and fill in your production values

# ═══════════════════════════════════════════════════════════════════════════════
# 📊 DATABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# PostgreSQL (Production)
DATABASE_URL=postgresql://user:password@localhost:5432/nekxuz_prod

# SQLite (Development Only)
# DATABASE_URL=file:./dev.sqlite

# Database Credentials
DB_USER=nekxuz
DB_PASSWORD=your_secure_password_here
DB_NAME=nekxuz_prod
DB_PORT=5432

# ═══════════════════════════════════════════════════════════════════════════════
# 🖥️  APPLICATION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Environment
NODE_ENV=production
PORT=3002
LOG_LEVEL=info

# Frontend
REACT_APP_API_URL=https://api.nekxuz.com
REACT_APP_ENV=production

# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 SECURITY & AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════════════════

# Admin Portal Password
ADMIN_PASSWORD=your_secure_admin_password

# Session Secret (use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=generate_secure_random_32_char_string_here

# CORS Configuration
CORS_ORIGIN=https://nekxuz.com,https://www.nekxuz.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100   # Max requests per window

# ═══════════════════════════════════════════════════════════════════════════════
# 🔥 FIREBASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# ═══════════════════════════════════════════════════════════════════════════════
# 💳 PAYMENT GATEWAY (RAZORPAY)
# ═══════════════════════════════════════════════════════════════════════════════

# Razorpay Live Keys (NOT Test Keys!)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_live_razorpay_secret_key

# Razorpay Test Keys (Development Only)
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_test_razorpay_secret_key

# ═══════════════════════════════════════════════════════════════════════════════
# 🚚 SHIPPING INTEGRATION (SHIPROCKET)
# ═══════════════════════════════════════════════════════════════════════════════

SHIPROCKET_EMAIL=your_shiprocket_email@domain.com
SHIPROCKET_PASSWORD=your_shiprocket_password
SHIPROCKET_AUTH_TOKEN=your_shiprocket_auth_token

# ═══════════════════════════════════════════════════════════════════════════════
# 📧 EMAIL SERVICE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Gmail (Recommended)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password  # Use App Password, not Gmail password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Alternative: Custom SMTP
# EMAIL_SERVICE=custom
# SMTP_HOST=your_smtp_host.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@domain.com
# SMTP_PASS=your_smtp_password

# Alternative: SendGrid
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# ═══════════════════════════════════════════════════════════════════════════════
# 💾 STORAGE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Firebase Storage (Recommended)
STORAGE_TYPE=firebase

# Alternative: AWS S3
# STORAGE_TYPE=aws-s3
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=nekxuz-storage
# AWS_S3_REGION=ap-south-1

# ═══════════════════════════════════════════════════════════════════════════════
# 🔄 CACHING CONFIGURATION (REDIS)
# ═══════════════════════════════════════════════════════════════════════════════

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=  # Leave empty if no authentication

# ═══════════════════════════════════════════════════════════════════════════════
# 📊 MONITORING & LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn_url

# Application Insights (Azure)
APPINSIGHTS_INSTRUMENTATION_KEY=your_appinsights_key

# Datadog
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key

# ═══════════════════════════════════════════════════════════════════════════════
# 🔗 EXTERNAL SERVICES
# ═══════════════════════════════════════════════════════════════════════════════

# Google Maps API (for location services)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Gemini AI (for AI Assistant)
GOOGLE_AI_API_KEY=your_gemini_api_key

# ═══════════════════════════════════════════════════════════════════════════════
# 🌍 DOMAIN & DEPLOYMENT
# ═══════════════════════════════════════════════════════════════════════════════

# Your domain name
DOMAIN=nekxuz.com
DOMAIN_FULL=https://nekxuz.com

# API domain (can be different from main domain)
API_DOMAIN=api.nekxuz.com
API_DOMAIN_FULL=https://api.nekxuz.com

# ═══════════════════════════════════════════════════════════════════════════════
# 🛠️  DEVELOPMENT & DEBUGGING (Development Only)
# ═══════════════════════════════════════════════════════════════════════════════

# Debug mode (false for production)
DEBUG=false

# Verbose logging
VERBOSE_LOGGING=false

# Mock external services (for testing)
MOCK_RAZORPAY=false
MOCK_SHIPROCKET=false
MOCK_EMAIL=false

# ═══════════════════════════════════════════════════════════════════════════════
# ⚙️  FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable/disable features
ENABLE_AI_ASSISTANT=true
ENABLE_WHOLESALE=true
ENABLE_RETAIL=true
ENABLE_MANUFACTURING=false
ENABLE_GLOBAL_MARKETPLACE=false

# ═══════════════════════════════════════════════════════════════════════════════

# 📋 NOTES:
# 1. NEVER commit .env or .env.production to version control
# 2. Use strong, unique passwords for all services
# 3. Rotate sensitive keys regularly
# 4. Use environment variables for all secrets (NEVER hardcode)
# 5. Test all configurations before production deployment
# 6. Keep backups of all credentials
# 7. Monitor access logs for suspicious activity
# 8. Set up alerts for failed payments or errors

# 🔗 Setup Guides:
# - Firebase: https://firebase.google.com/docs/setup
# - Razorpay: https://razorpay.com/docs
# - Shiprocket: https://shiprocket.in/docs
# - Gmail App Password: https://support.google.com/accounts/answer/185833
# - Sentry: https://docs.sentry.io/product/releases/

