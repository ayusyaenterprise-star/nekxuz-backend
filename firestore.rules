rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Orders - readable by all, writable by backend
    match /orders/{orderId} {
      allow read: if true;
      allow write: if request.auth == null; // Backend via admin SDK
    }
    
    // Payments - writable by backend only
    match /payments/{paymentId} {
      allow read: if true;
      allow write: if request.auth == null;
    }
    
    // Shipments - writable by backend only
    match /shipments/{shipmentId} {
      allow read: if true;
      allow write: if request.auth == null;
    }
    
    // Products - public read
    match /products/{productId} {
      allow read: if true;
      allow write: if false;
    }
  }
}